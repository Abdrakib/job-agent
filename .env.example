# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_key_here

# JSearch (RapidAPI) — for job discovery
RAPIDAPI_KEY=your_rapidapi_key_here

# SendGrid — for daily email reports
SENDGRID_API_KEY=your_sendgrid_key_here

# GitHub — for syncing your project bank
GITHUB_TOKEN=your_github_token_here
GITHUB_USERNAME=Abdrakib

# LinkedIn — for Easy Apply automation
LINKEDIN_EMAIL=Rakibabente8@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password_here

# PostgreSQL — auto-generated by docker-compose, change the password
POSTGRES_PASSWORD=choose_a_strong_password_here
DATABASE_URL=postgresql://jobagent:your_password@localhost:5432/jobagent

# Gmail — for inbox monitoring
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8080

# Your app URL (set after deployment)
APP_URL=your_droplet_ip:8501

# Agent settings (also configurable in dashboard)
MAX_JOBS_PER_RUN=100
MIN_MATCH_SCORE=70
MAX_AUTO_APPLY_PER_DAY=20
FOLLOW_UP_DAYS=7
